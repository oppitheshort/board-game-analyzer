{
  "manifest_version": 3,
  "name": "Board Game Analyzer",
  "version": "0.1.0",
  "description": "Real-time board game analysis with momentum tracking for Board Game Arena",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://boardgamearena.com/*",
    "*://en.boardgamearena.com/*",
    "http://217.77.1.42/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://boardgamearena.com/*",
        "*://en.boardgamearena.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar/index.html"],
      "matches": [
        "*://boardgamearena.com/*",
        "*://en.boardgamearena.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
